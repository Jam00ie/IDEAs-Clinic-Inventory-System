@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.CatalogItemComponents.EditModel
@{
    ViewData["Title"] = "Edit Catalog Item Component";
}

<h1>Edit Catalog Item Component</h1>

<form method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.RowVersion" />
    <div class="mb-3">
        <label asp-for="Input.CatalogItemId" class="form-label"></label>
        <select asp-for="Input.CatalogItemId" asp-items="Model.CatalogItemOptions" class="form-select"></select>
        <span asp-validation-for="Input.CatalogItemId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" autofocus />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.ExpectedQuantity" class="form-label"></label>
        <input asp-for="Input.ExpectedQuantity" class="form-control" />
        <span asp-validation-for="Input.ExpectedQuantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
