@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.UntrackedUnits.EditModel
@{
    ViewData["Title"] = "Edit Untracked Units";
}

<h1>Edit Untracked Units</h1>

<form method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.RowVersion" />
    <div class="mb-3">
        <label asp-for="Input.CatalogItemId" class="form-label"></label>
        <select asp-for="Input.CatalogItemId" asp-items="Model.CatalogItemOptions" class="form-select"></select>
        <span asp-validation-for="Input.CatalogItemId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.LocationId" class="form-label"></label>
        <select asp-for="Input.LocationId" asp-items="Model.LocationOptions" class="form-select"></select>
        <span asp-validation-for="Input.LocationId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.QuantityAtLocation" class="form-label"></label>
        <input asp-for="Input.QuantityAtLocation" class="form-control" autofocus />
        <span asp-validation-for="Input.QuantityAtLocation" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Notes" class="form-label"></label>
        <textarea asp-for="Input.Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Input.Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
