@page
@model IdeasClinicInventory.Web.Pages.Admin.UntrackedUnits.IndexModel
@{
    ViewData["Title"] = "Untracked Units";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="status">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1>Untracked Units</h1>
        <p class="text-muted mb-0">Manage counted quantities grouped by catalog item and location.</p>
    </div>
    <a class="btn btn-primary" asp-page="Create" asp-route-catalogItemId="@Model.CatalogItemId" asp-route-locationId="@Model.LocationId">Create Untracked Units</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-sm-5">
        <label asp-for="CatalogItemId" class="form-label">Catalog Item</label>
        <select asp-for="CatalogItemId" asp-items="Model.CatalogItemOptions" class="form-select"><option value="">All Catalog Items</option></select>
    </div>
    <div class="col-sm-5">
        <label asp-for="LocationId" class="form-label">Inventory Location</label>
        <select asp-for="LocationId" asp-items="Model.LocationOptions" class="form-select"><option value="">All Locations</option></select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary" type="submit">Apply Filter</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Clear</a>
    </div>
</form>

@if (Model.UntrackedUnits.Count == 0)
{
    <div class="alert alert-info">No untracked units match this filter.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Entry</th><th>Quantity at Location</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.UntrackedUnits)
                {
                    <tr>
                        <td>@unit.DisplayName</td>
                        <td>@unit.QuantityAtLocation</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@unit.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@unit.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
