@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.InventoryLocations.DetailsModel
@{
    ViewData["Title"] = Model.Location.LocationCode;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1>@Model.Location.LocationCode</h1>
    <div>
        <a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.Location.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-page="Index">Back to Locations</a>
    </div>
</div>

<dl class="row details-list">
    <dt class="col-sm-4">Room Code</dt><dd class="col-sm-8">@Model.Location.RoomCode</dd>
    <dt class="col-sm-4">Storage Unit Level</dt><dd class="col-sm-8">@Model.Location.StorageUnitLevel</dd>
    <dt class="col-sm-4">Storage Unit Code</dt><dd class="col-sm-8">@Model.Location.StorageUnitCode</dd>
    <dt class="col-sm-4">Subunit</dt><dd class="col-sm-8">@(Model.Location.Subunit ?? "—")</dd>
    <dt class="col-sm-4">Reference Image Path</dt><dd class="col-sm-8 text-break">@(Model.Location.ReferenceImagePath ?? "—")</dd>
    <dt class="col-sm-4">Notes</dt><dd class="col-sm-8 preserve-lines">@(Model.Location.Notes ?? "—")</dd>
    <dt class="col-sm-4">Created</dt><dd class="col-sm-8">@Model.Location.CreatedAtUtc.ToLocalTime().ToString("g")</dd>
    <dt class="col-sm-4">Last Updated</dt><dd class="col-sm-8">@Model.Location.UpdatedAtUtc.ToLocalTime().ToString("g")</dd>
</dl>

<div class="d-flex align-items-center justify-content-between mt-5 mb-3">
    <h2>Tracked Units Stored Here (@Model.StoredTrackedUnits.Count)</h2>
</div>

@if (Model.StoredTrackedUnits.Count == 0)
{
    <p class="text-muted">No tracked units use this as their home location.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Unit</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.StoredTrackedUnits)
                {
                    <tr>
                        <td>@unit.DisplayName</td>
                        <td>@Html.DisplayFor(_ => unit.Status)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/TrackedUnits/Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/TrackedUnits/Edit" asp-route-id="@unit.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex align-items-center justify-content-between mt-5 mb-3">
    <h2>Untracked Units Stored Here (@Model.StoredUntrackedQuantity Total)</h2>
    <a class="btn btn-primary" asp-page="/Admin/UntrackedUnits/Create" asp-route-locationId="@Model.Location.Id">Add Untracked Units</a>
</div>

@if (Model.StoredUntrackedUnits.Count == 0)
{
    <p class="text-muted">No quantity-based stock is recorded at this location.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Catalog Item</th><th>Quantity at Location</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.StoredUntrackedUnits)
                {
                    <tr>
                        <td>@unit.CatalogItem.Name</td>
                        <td>@unit.QuantityAtLocation</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/UntrackedUnits/Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/UntrackedUnits/Edit" asp-route-id="@unit.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
