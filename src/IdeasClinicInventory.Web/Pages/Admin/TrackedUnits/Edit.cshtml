@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.TrackedUnits.EditModel
@{
    ViewData["Title"] = "Edit Tracked Unit";
}

<h1>Edit Tracked Unit</h1>

<form method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.RowVersion" />

    <div class="mb-3">
        <label asp-for="Input.CatalogItemId" class="form-label"></label>
        <select asp-for="Input.CatalogItemId" asp-items="Model.CatalogItemOptions" class="form-select"></select>
        <span asp-validation-for="Input.CatalogItemId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Identifier" class="form-label"></label>
        <input asp-for="Input.Identifier" class="form-control" autofocus />
        <span asp-validation-for="Input.Identifier" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.HomeLocationId" class="form-label"></label>
        <select asp-for="Input.HomeLocationId" asp-items="Model.HomeLocationOptions" class="form-select"></select>
        <span asp-validation-for="Input.HomeLocationId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Status" class="form-label"></label>
        <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<TrackedUnitStatus>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Notes" class="form-label"></label>
        <textarea asp-for="Input.Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Input.Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save changes</button>
    <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
