@page
@model IdeasClinicInventory.Web.Pages.Admin.TrackedUnits.IndexModel
@{
    ViewData["Title"] = "Tracked Units";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="status">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1>Tracked Units</h1>
        <p class="text-muted mb-0">Manage individually identifiable physical units.</p>
    </div>
    <a class="btn btn-primary" asp-page="Create" asp-route-catalogItemId="@Model.CatalogItemId">Create tracked unit</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-sm-6 col-lg-4">
        <label asp-for="CatalogItemId" class="form-label">Filter by catalog item</label>
        <select asp-for="CatalogItemId" asp-items="Model.CatalogItemOptions" class="form-select">
            <option value="">All catalog items</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary" type="submit">Apply filter</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Clear</a>
    </div>
</form>

@if (Model.TrackedUnits.Count == 0)
{
    <div class="alert alert-info">No tracked units match this filter.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Unit</th><th>Status</th><th>Home Location</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.TrackedUnits)
                {
                    <tr>
                        <td>@unit.DisplayName</td>
                        <td>@Html.DisplayFor(_ => unit.Status)</td>
                        <td>@unit.HomeLocation.LocationCode</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@unit.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@unit.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
