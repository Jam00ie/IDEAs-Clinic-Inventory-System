@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.CatalogItems.DetailsModel
@{
    ViewData["Title"] = Model.Item.Name;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1>@Model.Item.Name</h1>
    <div>
        <a class="btn btn-primary" asp-page="Edit" asp-route-id="@Model.Item.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-page="Index">Back to Catalog</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card h-100"><div class="card-body"><h2 class="h6 text-muted">Tracked Units</h2><p class="display-6 mb-0">@Model.TrackedUnits.Count</p></div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body"><h2 class="h6 text-muted">Untracked Quantity</h2><p class="display-6 mb-0">@Model.UntrackedQuantity</p></div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body"><h2 class="h6 text-muted">Total Counted Quantity</h2><p class="display-6 mb-0">@Model.TotalCountedQuantity</p></div></div></div>
</div>

<dl class="row details-list">
    <dt class="col-sm-4">Category</dt><dd class="col-sm-8">@(Model.Item.Category ?? "—")</dd>
    <dt class="col-sm-4">Unit of Measure</dt><dd class="col-sm-8">@(Model.Item.UnitOfMeasure ?? "—")</dd>
    <dt class="col-sm-4">Allowed Use</dt><dd class="col-sm-8">@Html.DisplayFor(model => model.Item.AllowedUseType)</dd>
    <dt class="col-sm-4">Access</dt><dd class="col-sm-8">@(Model.Item.RestrictedToAdmins ? "IDEAs Clinic administrators only" : "All Waterloo users")</dd>
    <dt class="col-sm-4">Reserved for Administrators</dt><dd class="col-sm-8">@Model.Item.QuantityReservedForAdmins</dd>
    <dt class="col-sm-4">Reference Image Path</dt><dd class="col-sm-8 text-break">@(Model.Item.ReferenceImagePath ?? "—")</dd>
    <dt class="col-sm-4">Notes</dt><dd class="col-sm-8 preserve-lines">@(Model.Item.Notes ?? "—")</dd>
    <dt class="col-sm-4">Created</dt><dd class="col-sm-8">@Model.Item.CreatedAtUtc.ToLocalTime().ToString("g")</dd>
    <dt class="col-sm-4">Last Updated</dt><dd class="col-sm-8">@Model.Item.UpdatedAtUtc.ToLocalTime().ToString("g")</dd>
</dl>

<div class="d-flex align-items-center justify-content-between mt-5 mb-3">
    <h2>Tracked Units (@Model.TrackedUnits.Count)</h2>
    <a class="btn btn-primary" asp-page="/Admin/TrackedUnits/Create" asp-route-catalogItemId="@Model.Item.Id">Add Tracked Units</a>
</div>

@if (Model.TrackedUnits.Count == 0)
{
    <p class="text-muted">No individually tracked units have been recorded for this catalog item.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Identifier</th><th>Status</th><th>Home Location</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.TrackedUnits)
                {
                    <tr>
                        <td>@unit.Identifier</td>
                        <td>@Html.DisplayFor(_ => unit.Status)</td>
                        <td>@unit.HomeLocation.LocationCode</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/TrackedUnits/Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/TrackedUnits/Edit" asp-route-id="@unit.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex align-items-center justify-content-between mt-5 mb-3">
    <h2>Untracked Units (@Model.UntrackedQuantity Total)</h2>
    <a class="btn btn-primary" asp-page="/Admin/UntrackedUnits/Create" asp-route-catalogItemId="@Model.Item.Id">Add Untracked Units</a>
</div>

@if (Model.UntrackedUnits.Count == 0)
{
    <p class="text-muted">No quantity-based stock has been recorded for this catalog item.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead><tr><th>Location</th><th>Quantity at Location</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var unit in Model.UntrackedUnits)
                {
                    <tr>
                        <td>@unit.Location.LocationCode</td>
                        <td>@unit.QuantityAtLocation</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/UntrackedUnits/Details" asp-route-id="@unit.Id">View</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/UntrackedUnits/Edit" asp-route-id="@unit.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
