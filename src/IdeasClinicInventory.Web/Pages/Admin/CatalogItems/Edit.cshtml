@page "{id:int}"
@model IdeasClinicInventory.Web.Pages.Admin.CatalogItems.EditModel
@{
    ViewData["Title"] = "Edit catalog item";
}

<h1>Edit catalog item</h1>

<form method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <input type="hidden" asp-for="Item.Id" />
    <input type="hidden" asp-for="Item.RowVersion" />

    <div class="mb-3">
        <label asp-for="Item.Name" class="form-label"></label>
        <input asp-for="Item.Name" class="form-control" autofocus />
        <span asp-validation-for="Item.Name" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Item.Category" class="form-label"></label>
            <input asp-for="Item.Category" class="form-control" />
            <span asp-validation-for="Item.Category" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Item.UnitOfMeasure" class="form-label"></label>
            <input asp-for="Item.UnitOfMeasure" class="form-control" />
            <span asp-validation-for="Item.UnitOfMeasure" class="text-danger"></span>
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Item.AllowedUseType" class="form-label"></label>
        <select asp-for="Item.AllowedUseType" asp-items="Html.GetEnumSelectList<AllowedUseType>()" class="form-select"></select>
    </div>
    <div class="form-check mb-3">
        <input asp-for="Item.RestrictedToAdmins" class="form-check-input" />
        <label asp-for="Item.RestrictedToAdmins" class="form-check-label"></label>
    </div>
    <div class="mb-3">
        <label asp-for="Item.QuantityReservedForAdmins" class="form-label"></label>
        <input asp-for="Item.QuantityReservedForAdmins" class="form-control" />
        <span asp-validation-for="Item.QuantityReservedForAdmins" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Item.ReferenceImagePath" class="form-label"></label>
        <input asp-for="Item.ReferenceImagePath" class="form-control" />
        <span asp-validation-for="Item.ReferenceImagePath" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Item.Notes" class="form-label"></label>
        <textarea asp-for="Item.Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Item.Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save changes</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
